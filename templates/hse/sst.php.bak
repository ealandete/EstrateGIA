<?php $ok = $_GET['ok'] ?? null; $seccion = $_GET['seccion'] ?? 'dashboard'; $anio = $_GET['anio'] ?? date('Y'); ?>
<?php if ($ok): ?><div class="alert alert-success">Registro guardado</div><?php endif; ?>

<div class="d-flex justify-content-between mb-2">
    <div>
        <h5 class="mb-0"><i class="fas fa-hard-hat me-2" style="color:#ffc107"></i>Seguridad y Salud en el Trabajo</h5>
        <small class="text-muted">ISO 45001:2018 · Decreto 1072/2015 · Res. 0312/2019 · <?= htmlspecialchars($empresa['empresa_nombre']) ?></small>
    </div>
    <div class="d-flex align-items-center gap-2">
        <select class="form-select form-select-sm" style="width:100px" onchange="location.href='?seccion=<?= $seccion ?>&anio='+this.value">
            <?php for ($y = date('Y'); $y >= 2023; $y--): ?>
            <option value="<?= $y ?>" <?= $y == $anio ? 'selected' : '' ?>><?= $y ?></option>
            <?php endfor; ?>
        </select>
    </div>
</div>

<!-- Nav tabs -->
<ul class="nav nav-tabs nav-tabs-scroll small mb-3">
    <?php
    $tabs = [
        'dashboard' => ['gauge-high', 'Dashboard'],
        'peligros' => ['triangle-exclamation', 'Peligros'],
        'incidentes' => ['clipboard-list', 'Incidentes'],
        'plan' => ['calendar-alt', 'Plan Anual'],
        'normatividad' => ['scale-balanced', 'Normatividad'],
        'ausentismo' => ['calendar-xmark', 'Ausentismo'],
        'capacitaciones' => ['graduation-cap', 'Capacitación'],
        'examenes' => ['stethoscope', 'Exámenes'],
        'inspecciones' => ['magnifying-glass', 'Inspecciones'],
        'emergencias' => ['tower-broadcast', 'Emergencias'],
        'reportes' => ['file-pdf', 'Reportes'],
    ];
    foreach ($tabs as $key => $tab):
    ?>
    <li class="nav-item">
        <a class="nav-link <?= $seccion == $key ? 'active' : '' ?>" href="?seccion=<?= $key ?>&anio=<?= $anio ?>">
            <i class="fas fa-<?= $tab[0] ?> me-1" style="font-size:0.65rem"></i><?= $tab[1] ?>
        </a>
    </li>
    <?php endforeach; ?>
</ul>

<?php if ($seccion == 'dashboard'): ?>
<!-- KPI Stat Cards -->
<div class="row g-3 mb-3">
