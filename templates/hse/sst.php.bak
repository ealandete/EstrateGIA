<!-- Modal Añadir KPI -->
<div class="modal fade" id="modalIndicador"><div class="modal-dialog"><form method="POST" action="/sst/indicador/crear" class="modal-content">
    <input type="hidden" name="empresa_id" value="<?= $empresaId ?>">
    <div class="modal-header"><h5>Añadir Indicador SST</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body">
        <input type="text" name="nombre" class="form-control form-control-sm mb-2" placeholder="Nombre del indicador *" required>
        <div class="row g-2 mb-2"><div class="col-6"><input type="text" name="formula" class="form-control form-control-sm" placeholder="Fórmula"></div><div class="col-6"><input type="text" name="unidad" class="form-control form-control-sm" placeholder="Unidad (%)"></div></div>
        <div class="row g-2"><div class="col-6"><input type="number" name="meta" class="form-control form-control-sm" placeholder="Meta" step="0.01"></div><div class="col-6"><input type="number" name="valor" class="form-control form-control-sm" placeholder="Valor actual" step="0.01"></div></div>
    </div>
    <div class="modal-footer"><button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button><button type="submit" class="btn btn-warning">Guardar</button></div>
</form></div></div>

<!-- Modal Reportar Incidente -->
<div class="modal fade" id="modalIncidente"><div class="modal-dialog"><form method="POST" action="/sst/incidente" class="modal-content">
    <input type="hidden" name="empresa_id" value="<?= $empresaId ?>">
    <div class="modal-header"><h5>Reportar Incidente SST</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body">
        <div class="row g-2 mb-2"><div class="col-6"><select name="tipo" class="form-select form-select-sm"><option value="accidente">Accidente</option><option value="incidente">Incidente</option><option value="casi_accidente">Casi Accidente</option><option value="enfermedad_laboral">Enfermedad Laboral</option></select></div><div class="col-6"><select name="gravedad" class="form-select form-select-sm"><option value="leve">Leve</option><option value="moderado">Moderado</option><option value="grave">Grave</option></select></div></div>
        <textarea name="descripcion" class="form-control form-control-sm mb-2" rows="3" placeholder="Descripción del incidente *" required></textarea>
        <input type="date" name="fecha" class="form-control form-control-sm" value="<?= date('Y-m-d') ?>">
    </div>
    <div class="modal-footer"><button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button><button type="submit" class="btn btn-danger">Reportar</button></div>
</form></div></div>

